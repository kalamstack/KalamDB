# KalamDB Test Configuration
# ===========================
# Set these environment variables to configure the test suite behavior.
# This file is automatically loaded when running tests.

# Target server settings for tests
# Pick one mode:
#
# 1. Existing single-node server
# KALAMDB_SERVER_TYPE=running
# KALAMDB_SERVER_URL=http://127.0.0.1:8080
#
# 2. Existing cluster
# KALAMDB_SERVER_TYPE=cluster
# KALAMDB_CLUSTER_URLS=http://127.0.0.1:8081,http://127.0.0.1:8082,http://127.0.0.1:8083
#
# 3. Fresh auto-started test server
# KALAMDB_SERVER_TYPE=fresh

# Root user password for authentication
# Uncomment and set to match your server's root password
# Default (when commented): kalamdb123 (for auto-started server)
KALAMDB_ROOT_PASSWORD=kalamdb123
KALAMDB_DATA_DIR=/tmp/kalamdb-test-data5

# Specify the server type to use for tests
# Options:
#   Fresh   - Auto-start a fresh KalamDB server for tests
#   Running - Use an existing running KalamDB server
#   Cluster - Use an existing KalamDB cluster
# Default (when commented): Fresh
# KALAMDB_SERVER_TYPE=running
